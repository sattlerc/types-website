cabal-version:      2.4
name:               types2026-website
version:            0.1.0.0
build-type:         Simple

executable site
  main-is:          site.hs
  build-depends:
    , base     >= 4.16.4.0 && < 4.22
    , filepath >= 1.4.2.2  && < 1.6
    , hakyll   >= 4.16.7.0 && < 5
  ghc-options:      -threaded -rtsopts -with-rtsopts=-N
  default-language: Haskell2010
